{
  "name": "content-vigilante",
  "version": "0.0.1",
  "private": true,
  "description": "Patrols your content for off-brand violations. An open-source brand voice auditor.",
  "license": "MIT",
  "author": "Sai Prathyaksh Kanagat",
  "homepage": "https://contentvigilante.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/content-vigilante/Content-Vigilante"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
