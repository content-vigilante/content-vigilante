{
  "name": "@content-vigilante/core",
  "version": "0.0.0",
  "description": "Core engine for Content Vigilante. Brand voice auditing, multi-judge scoring, multilingual.",
  "license": "MIT",
  "author": "Sai Prathyaksh Kanagat <saikanagat1117@gmail.com>",
  "homepage": "https://github.com/content-vigilante/Content-Vigilante",
  "repository": {
    "type": "git",
    "url": "https://github.com/content-vigilante/Content-Vigilante.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/content-vigilante/Content-Vigilante/issues",
  "keywords": [
    "ai",
    "llm",
    "brand-voice",
    "content-marketing",
    "audit",
    "anthropic",
    "openai",
    "ollama",
    "multilingual"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./extractors": "./src/extractors/index.ts",
    "./extractors/text": "./src/extractors/text.ts",
    "./guides": "./src/guides/index.ts",
    "./guides/loadFromJSON": "./src/guides/loadFromJSON.ts",
    "./judges/aggregator": "./src/judges/aggregator.ts",
    "./llm": "./src/llm/index.ts",
    "./embeddings": "./src/embeddings/index.ts",
    "./types": "./src/types.ts"
  },
  "files": ["src", "README.md", "LICENSE", "NOTICE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.2",
    "@ai-sdk/openai": "^4.0.3",
    "@mozilla/readability": "^0.6.0",
