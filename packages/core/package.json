    "franc": "^6.2.0",
    "linkedom": "^0.18.12",
    "ollama-ai-provider": "^1.0.0",
    "sqlite-vec": "^0.1.9",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  }
}
